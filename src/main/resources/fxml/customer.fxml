<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pet.management.view.controller.CustomerController"
      spacing="16">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
    
    <!-- 页面标题栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="顾客管理" styleClass="md-label-h3" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
    <!-- 操作工具栏 - 高频操作靠前 -->
    <HBox styleClass="md-card elevation-1" spacing="12" alignment="CENTER_LEFT">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16" />
        </padding>
        
        <!-- 搜索框 -->
        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <TextField fx:id="searchField" promptText="搜索顾客/宠物名称..." 
                       styleClass="md-text-field-outlined" prefWidth="320">
                <HBox.margin>
                    <Insets right="8" />
                </HBox.margin>
            </TextField>
            
            <Button fx:id="searchBtn" text="搜索" styleClass="md-button" />
        </HBox>
        
        <Region HBox.hgrow="ALWAYS" />
        
        <!-- 操作按钮 - 按频率排序 -->
        <Button fx:id="addBtn" text="➕ 添加顾客" styleClass="md-button md-button-success" />
        <Button fx:id="refreshBtn" text="🔄 刷新" styleClass="md-button md-button-outlined" />
    </HBox>
    
    <!-- 统计卡片 -->
    <HBox spacing="16">
        <HBox.hgrow>
            <Priority value="ALWAYS" />
        </HBox.hgrow>
        
        <!-- 总顾客数 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="总顾客数" styleClass="md-label-caption" />
            <Label fx:id="totalCustomersLabel" text="0" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #2196F3;
                </style>
            </Label>
        </VBox>
        
        <!-- 活跃顾客 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="活跃顾客" styleClass="md-label-caption" />
            <Label fx:id="activeCustomersLabel" text="0" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #4CAF50;
                </style>
            </Label>
        </VBox>
        
        <!-- 本月新增 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="本月新增" styleClass="md-label-caption" />
            <Label fx:id="recentCustomersLabel" text="0" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #FF9800;
                </style>
            </Label>
        </VBox>
    </HBox>
    
    <!-- 顾客列表表格 -->
    <VBox styleClass="md-card elevation-1" spacing="0" VBox.vgrow="ALWAYS">
        <TableView fx:id="customerTable" styleClass="md-table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="customerNameColumn" text="顾客姓名" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="customerName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="phoneColumn" text="联系电话" prefWidth="130">
                    <cellValueFactory>
                        <PropertyValueFactory property="phone" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petNameColumn" text="宠物姓名" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="petName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petTypeColumn" text="宠物类型" prefWidth="90">
                    <cellValueFactory>
                        <PropertyValueFactory property="petType" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petBreedColumn" text="宠物品种" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="petBreed" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petAgeColumn" text="宠物年龄" prefWidth="80">
                    <cellValueFactory>
                        <PropertyValueFactory property="petAge" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="createTimeColumn" text="创建时间" prefWidth="160">
                    <cellValueFactory>
                        <PropertyValueFactory property="createTime" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="操作" prefWidth="150">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </VBox>
    
    <!-- 底部状态栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="statusLabel" text="就绪" styleClass="md-label-body2">
            <graphic>
                <Region styleClass="status-dot status-success" />
            </graphic>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
</VBox>
