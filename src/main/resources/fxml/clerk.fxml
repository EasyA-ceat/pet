<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="16">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
    
    <!-- 页面标题栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="员工管理" styleClass="md-label-h3" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
    <!-- 员工信息表单卡片 -->
    <VBox styleClass="md-card elevation-1" spacing="16">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24" />
        </padding>
        
        <Label text="员工信息" styleClass="md-label-h4" />
        
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="80" />
                <ColumnConstraints halignment="LEFT" hgrow="ALWAYS" minWidth="200" />
                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="80" />
                <ColumnConstraints halignment="LEFT" hgrow="ALWAYS" minWidth="200" />
            </columnConstraints>
            
            <!-- 员工姓名 -->
            <Label text="员工姓名:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" promptText="请输入员工姓名" 
                       styleClass="md-text-field-outlined" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <!-- 联系电话 -->
            <Label text="联系电话:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="phoneField" promptText="请输入联系电话" 
                       styleClass="md-text-field-outlined" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            
            <!-- 提成比例 -->
            <Label text="提成比例:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="commissionRateField" promptText="请输入提成比例(0-1)" 
                       styleClass="md-text-field-outlined" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <!-- 备注信息 -->
            <Label text="备注信息:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="notesField" promptText="请输入备注信息" 
                       styleClass="md-text-field-outlined" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        </GridPane>
        
        <!-- 操作按钮 - 按频率排序 -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button fx:id="addButton" text="➕ 添加" styleClass="md-button md-button-success" onAction="#addClerk" />
            <Button fx:id="editButton" text="✏️ 编辑" styleClass="md-button" onAction="#editClerk" />
            <Button fx:id="clearButton" text="🧹 清空" styleClass="md-button md-button-outlined" onAction="#clearForm" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <!-- 危险操作 - 删除 -->
            <Button fx:id="deleteButton" text="🗑️ 删除" styleClass="md-button md-button-danger" onAction="#deleteClerk" />
        </HBox>
    </VBox>
    
    <!-- 员工列表 -->
    <VBox styleClass="md-card elevation-1" spacing="0" VBox.vgrow="ALWAYS">
        <TableView fx:id="clerkTable" styleClass="md-table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="nameColumn" text="姓名" prefWidth="150">
                    <cellValueFactory>
                        <PropertyValueFactory property="name" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="phoneColumn" text="电话" prefWidth="150">
                    <cellValueFactory>
                        <PropertyValueFactory property="phone" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="commissionRateColumn" text="提成比例" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="commissionRate" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="notesColumn" text="备注" prefWidth="200">
                    <cellValueFactory>
                        <PropertyValueFactory property="notes" />
                    </cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </VBox>
    
    <!-- 底部状态栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="statusLabel" text="就绪" styleClass="md-label-body2">
            <graphic>
                <Region styleClass="status-dot status-success" />
            </graphic>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
</VBox>
