<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      styleClass="page-container"
      spacing="20">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
    
    <!-- 页面标题与操作 -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label styleClass="page-title" text="财务管理" />
            <Label styleClass="page-subtitle" text="管理交易记录和财务数据" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="12">
            <Button fx:id="calculateCommissionBtn" styleClass="btn btn-secondary" text="📊 计算提成" />
            <Button fx:id="addBtn" styleClass="btn btn-primary" text="➕ 添加交易" />
        </HBox>
    </HBox>
    
    <!-- 统计摘要 -->
    <GridPane hgap="16">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
        </columnConstraints>
        
        <VBox styleClass="card shadow-sm" spacing="8" GridPane.columnIndex="0">
            <Label styleClass="stat-label" text="总交易额" />
            <Label fx:id="totalAmountLabel" styleClass="stat-value" text="¥0.00" />
        </VBox>
        
        <VBox styleClass="card shadow-sm" spacing="8" GridPane.columnIndex="1">
            <Label styleClass="stat-label" text="总提成" />
            <Label fx:id="totalCommissionLabel" styleClass="stat-value" text="¥0.00" />
        </VBox>
        
        <VBox styleClass="card shadow-sm" spacing="8" GridPane.columnIndex="2">
            <Label styleClass="stat-label" text="交易笔数" />
            <Label fx:id="transactionCountLabel" styleClass="stat-value" text="0" />
        </VBox>
        
        <VBox styleClass="card shadow-sm" spacing="8" GridPane.columnIndex="3">
            <Label styleClass="stat-label" text="平均交易额" />
            <Label fx:id="averageAmountLabel" styleClass="stat-value" text="¥0.00" />
        </VBox>
    </GridPane>
    
    <!-- 筛选与搜索 -->
    <HBox styleClass="filter-bar shadow-sm" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" styleClass="search-input" promptText="搜索顾客、宠物、服务类型..." prefWidth="360" />
        <Button fx:id="searchBtn" styleClass="btn btn-primary" text="🔍 搜索" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="refreshBtn" styleClass="btn btn-secondary" text="🔄 刷新" />
    </HBox>
    
    <!-- 交易记录表格 -->
    <VBox styleClass="card shadow-md" spacing="0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16" />
        </padding>
        
        <TableView fx:id="transactionTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="customerNameColumn" text="顾客姓名" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="customerName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petNameColumn" text="宠物姓名" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="petName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="clerkNameColumn" text="员工姓名" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="clerkName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="transactionDateColumn" text="交易日期" prefWidth="150">
                    <cellValueFactory>
                        <PropertyValueFactory property="transactionDate" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="serviceTypeColumn" text="服务类型" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="serviceType" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="amountColumn" text="金额" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="amount" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="commissionColumn" text="提成" prefWidth="90">
                    <cellValueFactory>
                        <PropertyValueFactory property="commission" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="notesColumn" text="备注" prefWidth="150">
                    <cellValueFactory>
                        <PropertyValueFactory property="notes" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="操作" prefWidth="140">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </VBox>
    
    <!-- 底部状态栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="statusLabel" styleClass="stat-label" text="就绪" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
</VBox>
