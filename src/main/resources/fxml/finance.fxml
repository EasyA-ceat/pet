<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pet.management.view.controller.FinanceController"
      spacing="16">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
    
    <!-- 页面标题栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="财务管理" styleClass="md-label-h3" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
    <!-- 统计卡片 - 顶部优先展示 -->
    <HBox spacing="16">
        <HBox.hgrow>
            <Priority value="ALWAYS" />
        </HBox.hgrow>
        
        <!-- 总交易额 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="总交易额" styleClass="md-label-caption" />
            <Label fx:id="totalAmountLabel" text="¥0.00" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #2196F3;
                </style>
            </Label>
        </VBox>
        
        <!-- 总提成 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="总提成" styleClass="md-label-caption" />
            <Label fx:id="totalCommissionLabel" text="¥0.00" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #4CAF50;
                </style>
            </Label>
        </VBox>
        
        <!-- 交易笔数 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="交易笔数" styleClass="md-label-caption" />
            <Label fx:id="transactionCountLabel" text="0" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #FF9800;
                </style>
            </Label>
        </VBox>
        
        <!-- 平均交易额 -->
        <VBox styleClass="md-card elevation-1" spacing="8" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20" />
            </padding>
            <Label text="平均交易额" styleClass="md-label-caption" />
            <Label fx:id="averageAmountLabel" text="¥0.00" styleClass="md-label-h2">
                <style>
                    -fx-text-fill: #9C27B0;
                </style>
            </Label>
        </VBox>
    </HBox>
    
    <!-- 操作工具栏 - 高频操作靠前 -->
    <HBox styleClass="md-card elevation-1" spacing="12" alignment="CENTER_LEFT">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16" />
        </padding>
        
        <!-- 搜索框 -->
        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <TextField fx:id="searchField" promptText="搜索顾客/宠物/服务类型..." 
                       styleClass="md-text-field-outlined" prefWidth="320">
                <HBox.margin>
                    <Insets right="8" />
                </HBox.margin>
            </TextField>
            
            <Button fx:id="searchBtn" text="搜索" styleClass="md-button" />
        </HBox>
        
        <Region HBox.hgrow="ALWAYS" />
        
        <!-- 操作按钮 - 按频率排序 -->
        <Button text="➕ 添加交易" fx:id="addBtn" styleClass="md-button md-button-success" />
        <Button text="📊 计算提成" fx:id="calculateCommissionBtn" styleClass="md-button md-button-info" />
        <Button text="🔄 刷新" fx:id="refreshBtn" styleClass="md-button md-button-outlined" />
    </HBox>
    
    <!-- 交易记录表格 -->
    <VBox styleClass="md-card elevation-1" spacing="0" VBox.vgrow="ALWAYS">
        <TableView fx:id="transactionTable" styleClass="md-table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="customerNameColumn" text="顾客姓名" prefWidth="110">
                    <cellValueFactory>
                        <PropertyValueFactory property="customerName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="petNameColumn" text="宠物姓名" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="petName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="clerkNameColumn" text="员工姓名" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="clerkName" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="transactionDateColumn" text="交易日期" prefWidth="140">
                    <cellValueFactory>
                        <PropertyValueFactory property="transactionDate" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="serviceTypeColumn" text="服务类型" prefWidth="110">
                    <cellValueFactory>
                        <PropertyValueFactory property="serviceType" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="amountColumn" text="金额" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="amount" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="commissionColumn" text="提成" prefWidth="90">
                    <cellValueFactory>
                        <PropertyValueFactory property="commission" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="notesColumn" text="备注" prefWidth="140">
                    <cellValueFactory>
                        <PropertyValueFactory property="notes" />
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="操作" prefWidth="140">
                    <cellValueFactory>
                        <PropertyValueFactory property="id" />
                    </cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </VBox>
    
    <!-- 底部状态栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="statusLabel" text="就绪" styleClass="md-label-body2">
            <graphic>
                <Region styleClass="status-dot status-success" />
            </graphic>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
</VBox>
