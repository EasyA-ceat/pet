<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefHeight="600.0" prefWidth="800.0">
    <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
        <Label text="财务管理" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #333333;">
            <VBox.margin>
                <Insets top="10.0" bottom="10.0"/>
            </VBox.margin>
        </Label>
        
        <Separator/>
        
        <VBox alignment="TOP_LEFT" spacing="10.0" prefWidth="600.0">
            <Label text="交易记录" style="-fx-font-size: 18px; -fx-font-weight: bold;">
                <VBox.margin>
                    <Insets bottom="10.0"/>
                </VBox.margin>
            </Label>
            
            <TableView fx:id="transactionTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="customerNameColumn" text="顾客姓名" prefWidth="120">
                        <cellValueFactory>
                            <PropertyValueFactory property="customerName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="petNameColumn" text="宠物姓名" prefWidth="120">
                        <cellValueFactory>
                            <PropertyValueFactory property="petName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="clerkNameColumn" text="员工姓名" prefWidth="120">
                        <cellValueFactory>
                            <PropertyValueFactory property="clerkName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="transactionDateColumn" text="交易日期" prefWidth="150">
                        <cellValueFactory>
                            <PropertyValueFactory property="transactionDate" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="serviceTypeColumn" text="服务类型" prefWidth="120">
                        <cellValueFactory>
                            <PropertyValueFactory property="serviceType" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="amountColumn" text="金额" prefWidth="100">
                        <cellValueFactory>
                            <PropertyValueFactory property="amount" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="commissionColumn" text="提成" prefWidth="100">
                        <cellValueFactory>
                            <PropertyValueFactory property="commission" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="操作" prefWidth="150">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>
        
        <Separator/>
        
        <VBox alignment="TOP_LEFT" spacing="10.0" prefWidth="600.0">
            <Label text="财务统计" style="-fx-font-size: 18px; -fx-font-weight: bold;">
                <VBox.margin>
                    <Insets bottom="10.0"/>
                </VBox.margin>
            </Label>
            
            <GridPane hgap="10.0" vgap="10.0">
                <Label text="总交易额:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="totalAmountLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                
                <Label text="总提成:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="totalCommissionLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                
                <Label text="交易笔数:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="transactionCountLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                
                <Label text="平均交易额:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="averageAmountLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>
        </VBox>
        
        <Separator/>
        
        <HBox alignment="CENTER" spacing="20.0" prefHeight="50.0">
            <Button text="添加交易" fx:id="addButton" prefWidth="100.0">
                <HBox.margin>
                    <Insets top="10.0" bottom="10.0"/>
                </HBox.margin>
            </Button>
            
            <Button text="编辑交易" fx:id="editButton" prefWidth="100.0">
                <HBox.margin>
                    <Insets top="10.0" bottom="10.0"/>
                </HBox.margin>
            </Button>
            
            <Button text="删除交易" fx:id="deleteButton" prefWidth="100.0">
                <HBox.margin>
                    <Insets top="10.0" bottom="10.0"/>
                </HBox.margin>
            </Button>
            
            <Button text="刷新" fx:id="refreshButton" prefWidth="100.0">
                <HBox.margin>
                    <Insets top="10.0" bottom="10.0"/>
                </HBox.margin>
            </Button>
        </HBox>
    </VBox>
</AnchorPane>