<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      styleClass="page-container"
      spacing="20">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
    
    <!-- 页面标题与操作 -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label styleClass="page-title" text="报表中心" />
            <Label styleClass="page-subtitle" text="生成和导出各类业务报表" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
    <!-- 报表类型选择 -->
    <VBox styleClass="card shadow-md" spacing="20">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24" />
        </padding>
        
        <Label styleClass="section-title" text="报表类型" />
        
        <HBox spacing="16" alignment="CENTER_LEFT">
            <Button fx:id="dailyReportButton" styleClass="btn btn-primary" text="📅 日报" 
                    onAction="#generateDailyReport" prefWidth="140" />
            <Button fx:id="monthlyReportButton" styleClass="btn btn-primary" text="📆 月报" 
                    onAction="#generateMonthlyReport" prefWidth="140" />
            <Button fx:id="annualReportButton" styleClass="btn btn-primary" text="📊 年报" 
                    onAction="#generateAnnualReport" prefWidth="140" />
        </HBox>
    </VBox>
    
    <!-- 报表预览区域 -->
    <VBox styleClass="card shadow-md" spacing="20" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24" />
        </padding>
        
        <Label styleClass="section-title" text="报表预览" />
        
        <TextArea fx:id="reportPreview" styleClass="modern-textarea" 
                  prefHeight="300" editable="false" VBox.vgrow="ALWAYS" />
    </VBox>
    
    <!-- 导出操作栏 -->
    <HBox styleClass="card shadow-md" spacing="16" alignment="CENTER_LEFT">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24" />
        </padding>
        
        <Label styleClass="stat-label" text="导出选项:" />
        
        <Region HBox.hgrow="ALWAYS" />
        
        <Button fx:id="exportPdfButton" styleClass="btn btn-primary" text="📄 导出PDF" 
                onAction="#exportPdfReport" />
        <Button fx:id="exportExcelButton" styleClass="btn btn-secondary" text="📊 导出Excel" 
                onAction="#exportExcelReport" />
        <Button fx:id="generateChartButton" styleClass="btn btn-outline" text="📈 生成图表" 
                onAction="#generateSalesChart" />
        <Button fx:id="refreshButton" styleClass="btn btn-secondary" text="🔄 刷新" />
    </HBox>
    
    <!-- 底部状态栏 -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="statusLabel" styleClass="stat-label" text="就绪" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>
    
</VBox>
